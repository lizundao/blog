---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';
import { getPostsByCategory, POST_CATEGORIES } from '@/lib/posts';

const posts = await getPostsByCategory('work');
const meta = POST_CATEGORIES.work;
---

<BaseLayout title={meta.label} description={meta.description}>
  <section class="section-shell py-12 sm:py-16">
    <header class="mb-10 max-w-2xl space-y-3">
      <p class="font-mono text-xs text-muted-foreground">
        <span class="text-primary">ls</span> ./works
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">{meta.label}</h1>
      <p class="text-muted-foreground">{meta.description}</p>
    </header>

    <div class="post-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
