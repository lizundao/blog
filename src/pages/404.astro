---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404">
  <section class="section-shell flex min-h-[50dvh] flex-col items-center justify-center py-20 text-center">
    <p class="font-mono text-xs text-muted-foreground">
      <span class="text-primary">$</span> curl /unknown-route
    </p>
    <h1 class="mt-4 text-5xl font-bold tracking-tight text-ink">404</h1>
    <p class="mt-3 text-muted-foreground">这个路径还没有被构建出来。</p>
    <a href="/" class="mt-8 inline-flex h-10 items-center rounded-md border border-border bg-card px-5 font-mono text-xs transition-colors hover:border-primary/40">
      返回首页
    </a>
  </section>
</BaseLayout>
