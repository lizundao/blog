---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';
---

<BaseLayout title="未找到页面" description="你要找的路径不存在，或尚未写下。">
  <section class="section-shell flex min-h-[50dvh] flex-col items-center justify-center py-16 text-center sm:py-20">
    <p class="font-poem text-sm text-primary/90">此路暂未通</p>
    <h1 class="mt-4 font-brush text-5xl text-ink sm:text-6xl">404</h1>
    <p class="mt-4 max-w-sm text-base leading-relaxed text-muted-foreground">
      你要找的路径不存在，或尚未写下。不妨回首页看看，或去随笔、造物处转转。
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="inline-flex h-10 items-center rounded-md bg-primary px-5 font-mono text-xs font-medium text-primary-foreground transition-transform active:scale-[0.98] motion-reduce:active:scale-100"
      >
        返回首页
      </a>
      <a
        href="/essay"
        class="inline-flex h-10 items-center rounded-md border border-border bg-card px-5 font-mono text-xs text-foreground transition-colors hover:border-primary/40 hover:bg-accent"
      >
        读随笔
      </a>
      <a
        href="/works"
        class="inline-flex h-10 items-center rounded-md border border-border bg-card px-5 font-mono text-xs text-foreground transition-colors hover:border-primary/40 hover:bg-accent"
      >
        看造物
      </a>
    </div>
    <p class="mt-10 font-poem text-xs text-muted-foreground">{site.slogan}</p>
  </section>
</BaseLayout>
