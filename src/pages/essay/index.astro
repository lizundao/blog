---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';
import { getPostsByCategory, POST_CATEGORIES } from '@/lib/posts';

const posts = await getPostsByCategory('essay');
const meta = POST_CATEGORIES.essay;
---

<BaseLayout title={meta.label} description={meta.description}>
  <section class="section-shell py-12 sm:py-16">
    <header class="mb-10 max-w-2xl space-y-3">
      <p class="font-mono text-xs text-muted-foreground">
        <span class="text-primary">ls</span> ./essay
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">{meta.label}</h1>
      <p class="text-muted-foreground">{meta.description}</p>
    </header>

    {
      posts.length > 0 ? (
        <div class="post-grid">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-dashed border-border bg-card/40 px-6 py-12 text-center">
          <p class="text-muted-foreground">还没有随笔，第一篇正在路上。</p>
          <a href="/works" class="mt-4 inline-block font-mono text-xs text-primary hover:opacity-80">
            先看看造物 →
          </a>
        </div>
      )
    }
  </section>
</BaseLayout>
