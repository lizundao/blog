---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Prose from '@/components/shared/Prose.astro';
import AuthorCard from '@/components/blog/AuthorCard.astro';
import { formatDate } from '@/lib/posts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { title, description, pubDate, tags } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="section-shell py-10 sm:py-14">
    <header class="mb-8 max-w-3xl border-b border-border pb-8 lg:mb-10">
      <p class="mb-4 font-mono text-xs text-muted-foreground">
        <span class="text-primary">cat</span> ./posts/{title.toLowerCase().replace(/\s+/g, '-')}.md
      </p>
      <h1 class="text-3xl font-bold leading-tight tracking-tight text-ink sm:text-4xl">{title}</h1>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground">{description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-3 font-mono text-xs text-muted-foreground">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {
          tags.map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))
        }
      </div>
    </header>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px] lg:gap-12">
      <div class="min-w-0 max-w-3xl">
        <div class="mb-8 lg:hidden">
          <AuthorCard variant="compact" />
        </div>
        <Prose>
          <slot />
        </Prose>
      </div>

      <aside class="hidden lg:sticky lg:top-24 lg:block lg:self-start">
        <AuthorCard />
      </aside>
    </div>
  </article>
</BaseLayout>
