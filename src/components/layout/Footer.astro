---
import { site } from '@/config/site';

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-border/80 bg-card/50">
  <div class="section-shell flex flex-col gap-4 py-8 sm:flex-row sm:items-center sm:justify-between">
    <div class="space-y-1">
      <p class="font-brush text-xl text-ink">{site.name}</p>
      <p class="text-sm text-muted-foreground">© {year} {site.author.name}</p>
    </div>
    <div class="flex flex-wrap items-center gap-4 font-mono text-xs text-muted-foreground">
      <a href="/rss.xml" class="transition-colors hover:text-primary">rss</a>
      <a href={site.links.github} class="transition-colors hover:text-primary" target="_blank" rel="noreferrer">
        github
      </a>
      <a href={site.links.email} class="transition-colors hover:text-primary">来信</a>
    </div>
  </div>
</footer>
