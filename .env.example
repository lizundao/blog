# 硅基流动（OpenAI 兼容接口）
# 密钥：https://cloud.siliconflow.cn/account/ak
# 复制本文件为 .env 并填入真实值：cp .env.example .env

ARTICLE_AI_API_KEY=sk-your-key-here
ARTICLE_AI_BASE_URL=https://api.siliconflow.cn/v1
ARTICLE_AI_MODEL=deepseek-ai/DeepSeek-V3

# 润色参数（可选）
ARTICLE_AI_TEMPERATURE=0.7
ARTICLE_AI_MAX_TOKENS=4096

# 兼容旧变量名（可留空，优先使用 ARTICLE_AI_*）
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=
# DEEPSEEK_MODEL=
